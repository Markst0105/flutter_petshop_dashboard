{
  "buildCommand": "flutter/bin/flutter build web --release --base-href \"/\"",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "FLUTTER_WEB_CANVASKIT_URL": "https://www.gstatic.com/flutter-canvaskit/",
    "FLUTTER_BUILD_MODE": "release"
  }
}